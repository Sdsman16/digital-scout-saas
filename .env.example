# Database
DATABASE_URL=postgresql://user:password@localhost:5432/digital_scout

# Flask
FLASK_ENV=development
FLASK_SECRET=change-me-in-production

# Slack (per-state webhook URLs — real values in .env, NOT here)
SLACK_WEBHOOK_TX=https://hooks.slack.com/services/YOUR/TX/WEBHOOK
SLACK_WEBHOOK_LA=https://hooks.slack.com/services/YOUR/LA/WEBHOOK
SLACK_WEBHOOK_NM=https://hooks.slack.com/services/YOUR/NM/WEBHOOK
SLACK_WEBHOOK_OK=https://hooks.slack.com/services/YOUR/OK/WEBHOOK
SLACK_WEBHOOK_WY=https://hooks.slack.com/services/YOUR/WY/WEBHOOK
SLACK_WEBHOOK_ND=https://hooks.slack.com/services/YOUR/ND/WEBHOOK

# Ollama (local LLM)
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:3b

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...

# Auth
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=...
AUTH0_CLIENT_SECRET=...
